@{
}
@using DotNet_Crud.Models;
@model Product

<h2>Update Products</h2>

<form asp-controller="Home" asp-action="UpdateData" method="post">
    <input value="@Model.Name" placeholder="Enter Product Name" name="Name" />
    <input value="@Model.Desc" placeholder="Enter Product Description" name="Desc" />
    <input value="@Model.Price" placeholder="Enter Product Price" name="Price" />
    <input type="submit" />
</form>